{
  "name": "ht-php-lsp",
  "displayName": "PHP Language Server",
  "description": "PHP language support powered by hightemp (Rust)",
  "version": "0.6.0",
  "publisher": "hightemp",
  "author": {
    "email": "hightemp.unknown@gmail.com",
    "name": "Anton"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hightemp/php-lsp"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:blade",
    "onLanguage:php",
    "onLanguage:twig",
    "workspaceContains:**/*.blade.php",
    "workspaceContains:**/*.twig",
    "workspaceContains:**/composer.json"
  ],
  "main": "./out/extension.js",
  "icon": "images/php-lsp-icon.png",
  "contributes": {
    "configuration": {
      "title": "PHP Language Server",
      "properties": {
        "phpLsp.enable": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable/disable PHP Language Server"
        },
        "phpLsp.phpVersion": {
          "type": "string",
          "default": "8.2",
          "enum": [
            "7.4",
            "8.0",
            "8.1",
            "8.2",
            "8.3",
            "8.4"
          ],
          "scope": "resource",
          "description": "Target PHP version for diagnostics and completion"
        },
        "phpLsp.serverPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Custom path to php-lsp binary (leave empty for bundled)"
        },
        "phpLsp.includePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Additional paths to include in indexing"
        },
        "phpLsp.excludePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Relative or absolute paths to exclude from workspace indexing"
        },
        "phpLsp.stubs.extensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Core",
            "SPL",
            "standard",
            "pcre",
            "date",
            "json",
            "mbstring",
            "ctype",
            "tokenizer",
            "dom",
            "SimpleXML",
            "PDO",
            "curl",
            "filter",
            "hash",
            "session",
            "soap",
            "Reflection",
            "random",
            "intl",
            "fileinfo",
            "openssl",
            "phar",
            "xml",
            "xmlreader",
            "xmlwriter",
            "zip",
            "zlib",
            "bcmath",
            "gd",
            "iconv",
            "mysqli",
            "sodium"
          ],
          "scope": "resource",
          "description": "PHP extensions to load stubs for. Leave unconfigured to use bundled defaults; set to an empty array to disable stubs."
        },
        "phpLsp.composer.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable composer.json autoload support"
        },
        "phpLsp.indexVendor": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Index vendor/ directory (lazy loading)"
        },
        "phpLsp.diagnostics.mode": {
          "type": "string",
          "default": "basic-semantic",
          "enum": [
            "off",
            "syntax-only",
            "basic-semantic"
          ],
          "enumDescriptions": [
            "No diagnostics",
            "Only syntax errors from parser",
            "Syntax errors + built-in php-lsp semantic diagnostics"
          ],
          "scope": "resource",
          "description": "Diagnostics mode"
        },
        "phpLsp.diagnostics.severity": {
          "type": "object",
          "default": {
            "unknownSymbols": "warning",
            "unused": "warning",
            "duplicateSymbols": "warning",
            "members": "warning",
            "typeCompatibility": "warning",
            "overrideSignatures": "warning",
            "phpVersion": "warning"
          },
          "properties": {
            "unknownSymbols": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "information",
                "hint"
              ],
              "default": "warning",
              "description": "Severity for unresolved classes, functions, imports, and variables."
            },
            "unused": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "information",
                "hint"
              ],
              "default": "warning",
              "description": "Severity for unused imports, variables, and parameters."
            },
            "duplicateSymbols": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "information",
                "hint"
              ],
              "default": "warning",
              "description": "Severity for duplicate symbol diagnostics."
            },
            "members": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "information",
                "hint"
              ],
              "default": "warning",
              "description": "Severity for unknown member, static/instance misuse, and visibility diagnostics."
            },
            "typeCompatibility": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "information",
                "hint"
              ],
              "default": "warning",
              "description": "Severity for argument count and type compatibility diagnostics."
            },
            "overrideSignatures": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "information",
                "hint"
              ],
              "default": "warning",
              "description": "Severity for incompatible override signature diagnostics."
            },
            "phpVersion": {
              "type": "string",
              "enum": [
                "off",
                "error",
                "warning",
                "information",
                "hint"
              ],
              "default": "warning",
              "description": "Severity for PHP-version-specific diagnostics."
            }
          },
          "additionalProperties": {
            "type": "string",
            "enum": [
              "off",
              "error",
              "warning",
              "information",
              "hint"
            ]
          },
          "scope": "resource",
          "description": "Per-category severity for php-lsp diagnostics. Use off to suppress a noisy category without disabling all diagnostics."
        },
        "phpLsp.diagnostics.memberTypeNodeBudget": {
          "type": "number",
          "default": 64,
          "minimum": 0,
          "scope": "resource",
          "description": "Maximum relevant AST nodes to inspect before skipping expensive member and type-compatibility diagnostics for a file. Set to 0 to disable this budget cap."
        },
        "phpLsp.diagnostics.partialAnalysisDiagnostic": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Publish an informational diagnostic when php-lsp skips member and type-compatibility diagnostics because the file exceeded the diagnostics budget."
        },
        "phpLsp.allowProjectCommands": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Allow executable analyzer and formatter settings from .php-lsp.toml. Keep disabled unless you trust the workspace."
        },
        "phpLsp.formatting.provider": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "none",
            "pint",
            "php-cs-fixer",
            "phpcbf",
            "custom"
          ],
          "enumDescriptions": [
            "Auto-detect Laravel Pint, php-cs-fixer, or phpcbf from Composer metadata",
            "Disable document formatting",
            "Run Laravel Pint on a temporary file",
            "Run php-cs-fixer on a temporary file",
            "Run phpcbf on a temporary file",
            "Run the custom formatting command"
          ],
          "scope": "resource",
          "description": "Formatter provider for textDocument/formatting"
        },
        "phpLsp.formatting.command": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Custom formatter command. Use {file} as the temporary PHP file placeholder; if omitted, the file path is appended."
        },
        "phpLsp.formatting.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "scope": "resource",
          "description": "External formatter timeout in milliseconds."
        },
        "phpLsp.phpstan.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Enable PHPStan diagnostics. Requires PHPStan to be installed in the workspace or configured command path."
        },
        "phpLsp.phpstan.command": {
          "type": "string",
          "default": "vendor/bin/phpstan analyse --error-format=json --no-progress --no-interaction {file}",
          "scope": "resource",
          "description": "PHPStan command template. Use {file} as the PHP file placeholder; command must print PHPStan JSON output."
        },
        "phpLsp.phpstan.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "scope": "resource",
          "description": "Maximum time in milliseconds to wait for PHPStan diagnostics per file."
        },
        "phpLsp.psalm.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Enable Psalm diagnostics. Requires Psalm to be installed in the workspace or configured command path."
        },
        "phpLsp.psalm.command": {
          "type": "string",
          "default": "vendor/bin/psalm --output-format=json --no-progress {file}",
          "scope": "resource",
          "description": "Psalm command template. Use {file} as the PHP file placeholder; command must print Psalm JSON output."
        },
        "phpLsp.psalm.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "scope": "resource",
          "description": "Maximum time in milliseconds to wait for Psalm diagnostics per file."
        },
        "phpLsp.analyzerCodeActions.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Enable opt-in quick fixes for PHPStan and Psalm diagnostics when diagnostic metadata is available."
        },
        "phpLsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "scope": "window",
          "description": "Trace LSP communication between client and server"
        },
        "phpLsp.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "scope": "window",
          "description": "Server log level"
        }
      }
    },
    "languages": [
      {
        "id": "blade",
        "aliases": [
          "Blade",
          "blade"
        ],
        "extensions": [
          ".blade.php"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "twig",
        "aliases": [
          "Twig",
          "twig"
        ],
        "extensions": [
          ".twig",
          ".html.twig"
        ],
        "configuration": "./twig-language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "phpLsp.restartServer",
        "title": "Restart Language Server",
        "category": "PHP"
      },
      {
        "command": "phpLsp.clearCacheAndRestart",
        "title": "Clear PHP LSP Cache and Restart",
        "category": "PHP"
      },
      {
        "command": "phpLsp.showStatus",
        "title": "Show Language Server Status",
        "category": "PHP"
      },
      {
        "command": "phpLsp.showServerVersion",
        "title": "Show Language Server Version",
        "category": "PHP"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run prepare:package && npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "check:cache-path": "node scripts/check-cache-path.mjs",
    "check:commands": "node scripts/check-commands.mjs",
    "prepare:package": "node scripts/prepare-package-metadata.mjs",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0"
  }
}
