{
  "name": "php-lsp",
  "displayName": "PHP Language Server",
  "description": "PHP language support powered by php-lsp (Rust)",
  "version": "0.4.0",
  "publisher": "php-lsp",
  "repository": {
    "type": "git",
    "url": "https://github.com/hightemp/php-lsp"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:php",
    "workspaceContains:**/composer.json"
  ],
  "main": "./out/extension.js",
  "icon": "images/php-lsp-icon.png",
  "contributes": {
    "configuration": {
      "title": "PHP Language Server",
      "properties": {
        "phpLsp.enable": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable/disable PHP Language Server"
        },
        "phpLsp.phpVersion": {
          "type": "string",
          "default": "8.2",
          "enum": [
            "7.4",
            "8.0",
            "8.1",
            "8.2",
            "8.3",
            "8.4"
          ],
          "scope": "resource",
          "description": "Target PHP version for diagnostics and completion"
        },
        "phpLsp.serverPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Custom path to php-lsp binary (leave empty for bundled)"
        },
        "phpLsp.includePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Additional paths to include in indexing"
        },
        "phpLsp.excludePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Relative or absolute paths to exclude from workspace indexing"
        },
        "phpLsp.stubs.extensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Core",
            "SPL",
            "standard",
            "pcre",
            "date",
            "json",
            "mbstring",
            "ctype",
            "tokenizer",
            "dom",
            "SimpleXML",
            "PDO",
            "curl",
            "filter",
            "hash",
            "session",
            "Reflection",
            "random",
            "intl",
            "fileinfo",
            "openssl",
            "phar",
            "xml",
            "xmlreader",
            "xmlwriter",
            "zip",
            "zlib",
            "bcmath",
            "gd",
            "iconv",
            "mysqli",
            "sodium"
          ],
          "scope": "resource",
          "description": "PHP extensions to load stubs for"
        },
        "phpLsp.composer.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable composer.json autoload support"
        },
        "phpLsp.indexVendor": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Index vendor/ directory (lazy loading)"
        },
        "phpLsp.diagnostics.mode": {
          "type": "string",
          "default": "basic-semantic",
          "enum": [
            "off",
            "syntax-only",
            "basic-semantic"
          ],
          "enumDescriptions": [
            "No diagnostics",
            "Only syntax errors from parser",
            "Syntax errors + unknown class/function detection"
          ],
          "scope": "resource",
          "description": "Diagnostics mode"
        },
        "phpLsp.formatting.provider": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "php-cs-fixer",
            "phpcbf",
            "custom"
          ],
          "enumDescriptions": [
            "Disable document formatting",
            "Run php-cs-fixer on a temporary file",
            "Run phpcbf on a temporary file",
            "Run the custom formatting command"
          ],
          "scope": "resource",
          "description": "External formatter provider for textDocument/formatting"
        },
        "phpLsp.formatting.command": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Custom formatter command. Use {file} as the temporary PHP file placeholder; if omitted, the file path is appended."
        },
        "phpLsp.phpstan.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Enable PHPStan diagnostics. Requires PHPStan to be installed in the workspace or configured command path."
        },
        "phpLsp.phpstan.command": {
          "type": "string",
          "default": "vendor/bin/phpstan analyse --error-format=json --no-progress --no-interaction {file}",
          "scope": "resource",
          "description": "PHPStan command template. Use {file} as the PHP file placeholder; command must print PHPStan JSON output."
        },
        "phpLsp.phpstan.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "scope": "resource",
          "description": "Maximum time in milliseconds to wait for PHPStan diagnostics per file."
        },
        "phpLsp.psalm.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Enable Psalm diagnostics. Requires Psalm to be installed in the workspace or configured command path."
        },
        "phpLsp.psalm.command": {
          "type": "string",
          "default": "vendor/bin/psalm --output-format=json --no-progress {file}",
          "scope": "resource",
          "description": "Psalm command template. Use {file} as the PHP file placeholder; command must print Psalm JSON output."
        },
        "phpLsp.psalm.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "scope": "resource",
          "description": "Maximum time in milliseconds to wait for Psalm diagnostics per file."
        },
        "phpLsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "scope": "window",
          "description": "Trace LSP communication between client and server"
        },
        "phpLsp.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "scope": "window",
          "description": "Server log level"
        }
      }
    },
    "commands": [
      {
        "command": "phpLsp.restartServer",
        "title": "Restart Language Server",
        "category": "PHP"
      },
      {
        "command": "phpLsp.showStatus",
        "title": "Show Language Server Status",
        "category": "PHP"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.5.0"
  }
}
